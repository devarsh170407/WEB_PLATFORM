// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Category {
  HTML_TEMPLATE
  REACT
  NEXTJS
  WORDPRESS
  VUE
  ANGULAR
  UI_KIT
  LANDING_PAGE
  ECOMMERCE
  ADMIN_DASHBOARD
  OTHER
}

model User {
  id               String    @id @default(cuid())
  clerkId          String    @unique
  email            String    @unique
  name             String?
  avatarUrl        String?
  role             Role      @default(BUYER)
  stripeConnectId  String?
  stripeOnboarded  Boolean   @default(false)
  bio              String?
  website          String?
  earnings         Float     @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  products  Product[]
  purchases Purchase[]
  reviews   Review[]
}

model Product {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  description  String        @db.Text
  price        Float
  category     Category
  techStack    String[]
  screenshots  String[]      // Supabase URLs
  fileUrl      String        // Supabase URL for ZIP
  previewUrl   String?
  status       ProductStatus @default(PENDING)
  featured     Boolean       @default(false)
  salesCount   Int           @default(0)
  sellerId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  seller    User       @relation(fields: [sellerId], references: [id])
  purchases Purchase[]
  reviews   Review[]

  @@index([category])
  @@index([status])
  @@index([sellerId])
}

model Purchase {
  id              String   @id @default(cuid())
  productId       String
  buyerId         String
  amount          Float
  platformFee     Float
  sellerAmount    Float
  stripeSessionId String   @unique
  stripePaymentId String?
  downloadUrl     String?
  downloadCount   Int      @default(0)
  createdAt       DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  buyer   User    @relation(fields: [buyerId], references: [id])

  @@index([buyerId])
  @@index([productId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  buyerId   String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  buyer   User    @relation(fields: [buyerId], references: [id])

  @@unique([productId, buyerId])
}
